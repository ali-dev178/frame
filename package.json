{
  "name": "frame",
  "private": true,
  "version": "0.1.0",
  "description": "Fit photos into any social format — losslessly — and turn them into videos with your music.",
  "author": "Muhammad Ali <ali.dev178@gmail.com>",
  "repository": "github:ali-dev178/frame",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "vite --mode desktop",
    "build": "npm run typecheck && vite build",
    "build:desktop": "npm run typecheck && vite build --mode desktop",
    "smoke:desktop": "npm run build:desktop && electron . --smoke",
    "dist": "npm run build:desktop && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p electron",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/browser": "^3.2.7",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "mediabunny": "^1.50.9",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^3.2.7"
  }
}
